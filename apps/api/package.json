{
  "name": "@napi-aguas/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @napi-aguas/shared build",
    "predev": "pnpm db:migrate",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "predev:docker": "pnpm db:migrate",
    "dev:docker": "pnpm exec nodemon --config nodemon.json",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seeds/index.ts --all",
    "db:seed:core": "tsx src/db/seeds/index.ts --core",
    "db:seed:agua-doce": "tsx src/db/seeds/index.ts --agua-doce",
    "db:seed:saude": "tsx src/db/seeds/index.ts --saude",
    "db:seed:litoral": "tsx src/db/seeds/index.ts --litoral",
    "db:seed:transportes": "tsx src/db/seeds/index.ts --transportes",
    "db:seed:admin": "tsx src/db/seeds/admin-only.ts",
    "db:create-user": "tsx src/scripts/create-user.ts",
    "db:clean": "tsx src/db/clean.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@fastify/compress": "^7.0.0",
    "@fastify/cors": "9",
    "@fastify/helmet": "11",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "9",
    "@napi-aguas/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "fastify": "4.25",
    "gdal-async": "^3.11.4",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "pino": "8.17",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.6",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.1.1",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "zod": "3.24.1"
  }
}
