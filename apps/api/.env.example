# API environment template

# Database connection strings
DATABASE_URL=postgresql://napiaguas:napiaguas_dev@localhost:5432/napiaguas_dev
TEST_DATABASE_URL=postgresql://napiaguas:napiaguas_dev@localhost:5432/napiaguas_test

# Connection pool (opcional)
DB_POOL_MIN=2
DB_POOL_MAX=10

# HTTP server
API_PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# JWT authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Bcrypt password hashing
BCRYPT_SALT_ROUNDS=10
